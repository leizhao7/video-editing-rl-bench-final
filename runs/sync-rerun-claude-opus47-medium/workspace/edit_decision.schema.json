{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "audio_filters": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "type": "array"
    },
    "checks_performed": {
      "oneOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "additionalProperties": true,
          "type": "object"
        }
      ]
    },
    "local_audio_shifts_ms": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "reason": {
            "type": "string"
          },
          "shift_ms": {
            "type": "number"
          },
          "source_end": {
            "minimum": 0,
            "type": "number"
          },
          "source_start": {
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "source_start",
          "source_end",
          "shift_ms"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "removed_damage_ranges": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "label": {
            "type": "string"
          },
          "output_end": {
            "minimum": 0,
            "type": "number"
          },
          "output_start": {
            "minimum": 0,
            "type": "number"
          },
          "reason": {
            "type": "string"
          },
          "source_end": {
            "minimum": 0,
            "type": "number"
          },
          "source_start": {
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "source_start",
          "source_end"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "segments": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "label": {
            "type": "string"
          },
          "output_end": {
            "minimum": 0,
            "type": "number"
          },
          "output_start": {
            "minimum": 0,
            "type": "number"
          },
          "reason": {
            "type": "string"
          },
          "source_end": {
            "minimum": 0,
            "type": "number"
          },
          "source_start": {
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "source_start",
          "source_end"
        ],
        "type": "object"
      },
      "minItems": 2,
      "type": "array"
    },
    "self_checks": {
      "additionalProperties": true,
      "type": "object"
    },
    "source_files": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "tools_used": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "source_files",
    "tools_used",
    "checks_performed",
    "segments",
    "local_audio_shifts_ms",
    "removed_damage_ranges"
  ],
  "type": "object"
}
